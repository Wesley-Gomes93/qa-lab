{
  "info": {
    "name": "JSONPlaceholder API",
    "description": "API tests for JSONPlaceholder (https://jsonplaceholder.typicode.com) - reliable for automation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://jsonplaceholder.typicode.com" }
  ],
  "item": [
    {
      "name": "List users",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users",
        "description": "List users - expects 200, array"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is array', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Single user",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/1",
        "description": "Get single user"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('User has id and email', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('email');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/users",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"John Doe\", \"username\": \"johndoe\", \"email\": \"john@example.com\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('User created with id', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update user",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/users/1",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"id\": 1, \"name\": \"Updated Name\", \"username\": \"updated\", \"email\": \"updated@example.com\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('User updated', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('name');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete user",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/users/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "User not found",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/99999"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 404', () => pm.response.to.have.status(404));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
