# Backend
PORT=4000

# Token para rotas de admin (se não definir, o padrão é "admin-qa-lab")
# ADMIN_TOKEN=admin-qa-lab

# Credenciais do usuário admin (seed no banco). Em CI, use GitHub Secrets.
# ADMIN_EMAIL=seu-admin@exemplo.com
# ADMIN_PASSWORD=sua-senha-segura

# PostgreSQL (use o mesmo user/senha/db do database/docker-compose.yml)
DATABASE_URL=postgresql://qa:qa123@localhost:5432/qalab
