{
  "name": "qa-lab",
  "version": "1.0.0",
  "private": true,
  "description": "Playground full-stack para testes e automação (MCP + agente)",
  "devDependencies": {
    "autocannon": "^7.14.0",
    "@eslint/js": "^9",
    "eslint": "^9",
    "eslint-plugin-mocha": "^10",
    "globals": "^15"
  },
  "scripts": {
    "db:up": "cd database && docker-compose up -d",
    "db:down": "cd database && docker-compose down",
    "backend:install": "cd backend && npm install",
    "backend:dev": "cd backend && npm run dev",
    "backend:test": "cd backend && npm test",
    "backend:coverage": "cd backend && npm run test:coverage",
    "load:test": "node scripts/load-test.js",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "tests:install": "cd tests && npm install",
    "test:cy": "cd tests && npm test",
    "test:pw": "cd tests && npm run pw:test",
    "test:all": "cd tests && npm run test:cy && npm run test:pw",
    "tests:run": "cd tests && npm test",
    "tests:pw": "cd tests && npm run pw:test",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:pw:ui": "cd tests && npm run pw:ui",
    "tests:pw:report": "cd tests && npm run pw:report",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:pw:security": "cd tests && npm run pw:security",
    "tests:report:unified": "cd tests && npm run report:unified",
    "tests:report:execution": "cd tests && npm run report:execution",
    "tests:execution": "cd tests && npm run test:execution",
    "tests:contract": "node tests/contract/validate-against-spec.js",
    "tests:report": "cd tests && npm run test:report",
    "lint": "eslint backend/ tests/ agents/ scripts/ qa-extended-lab/",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "eslint backend/",
    "lint:tests": "eslint tests/",
    "lint:agents": "eslint agents/",
    "lint:check": "node scripts/lint-check.js",
    "lint:all": "npm run lint:frontend && npm run lint",
    "tests:clean-users": "node scripts/clean-test-users.js",
    "tests:full": "npm run tests:clean-users && npm run tests:report",
    "agents:install": "cd agents && npm install",
    "agent": "cd agents && node qa-agent.js",
    "agent:run-tests": "cd agents && node qa-agent.js run_tests",
    "agent:run-tests:api": "cd agents && node qa-agent.js run_tests --suite api",
    "agent:run-tests:spec": "cd agents && node qa-agent.js run_tests --spec cypress/e2e/api/api-health.cy.js",
    "agent:demo": "npm run agent:run-tests:api",
    "agent:analyze-failures": "cd agents && node failure-analyzer-agent.js",
    "agent:full": "npm run tests:clean-users && cd agents && node qa-agent.js run_tests",
    "agent:test-writer": "cd agents && node test-writer-agent.js",
    "dev": "node scripts/start-dev.js",
    "extended:install": "cd qa-extended-lab && npm ci",
    "extended:api": "cd qa-extended-lab && npm run test:api",
    "extended:api:full": "cd qa-extended-lab && npm run test:api:full",
    "extended:a11y": "cd qa-extended-lab && npm run test:a11y",
    "extended:all": "cd qa-extended-lab && npm run test:all",
    "security:scan": "cd security-lab && ./scripts/run-security-scan.sh",
    "security:report": "cd security-lab && ./scripts/generate-report.sh",
    "audit:context": "node scripts/prepare-audit-context.js",
    "audit:context:incremental": "node scripts/prepare-audit-context.js --incremental"
  }
}
