# API Key para o Test Writer Agent (LLM)
# COPIE para .env: cp .env.example .env
# O .env NÃO é versionado (.gitignore)
#
# Opção 1 – Groq (GRATUITO, recomendado)
# https://console.groq.com/keys
GROQ_API_KEY=

# Opção 2 – Google Gemini (GRATUITO)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opção 3 – OpenAI (pago)
# OPENAI_API_KEY=

# Prioridade: GROQ > GEMINI > OPENAI
# QA_LAB_LLM_PROVIDER=groq|gemini|openai  (forçar provedor)
# QA_LAB_LLM_MODEL=llama-3.3-70b-versatile|gemini-1.5-flash|gpt-4o-mini
